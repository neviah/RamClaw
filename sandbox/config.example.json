{
  "llm": {
    "provider": "lmstudio",
    "endpoint": "http://127.0.0.1:1234/v1",
    "model": "REPLACE_WITH_LOCAL_MODEL_NAME",
    "streaming": true,
    "cloudProviders": false,
    "remoteTools": false
  },
  "sandbox": {
    "workspace": "/sandbox/workspace",
    "allowedReadRoots": [
      "/sandbox/workspace",
      "/sandbox/config.json",
      "__BUNDLED_OPENCLAW_PATH__"
    ],
    "allowedWriteRoot": "/sandbox/workspace"
  },
  "git": {
    "user": {
      "name": "RamClaw Agent",
      "email": "ramclaw@sandbox.local"
    },
    "sshKeyPath": "/sandbox/.ssh/id_rsa"
  }
}
